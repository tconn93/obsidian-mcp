# Server
PORT=8084
HOST=0.0.0.0

# Google OAuth — set GOOGLE_CLIENT_ID to enable authentication.
# Leave unset to disable auth (all requests pass through).
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional: restrict access to specific emails or domains (comma-separated).
# If both are unset, any valid Google token for the client ID is accepted.
GOOGLE_ALLOWED_EMAILS=your@email.com
GOOGLE_ALLOWED_DOMAINS=yourdomain.com

# Obsidian vaults directory
VAULT_DIR_PATH=/path/to/vault
